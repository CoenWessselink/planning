{
  "name": "cws-planning",
  "type": "module",
  "scripts": {
    "start": "node playwright/server.js",
    "dev": "wrangler d1 migrations apply cws-planning-intern --local && wrangler pages dev . --port 8788",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright test && node scripts/open_report_hint.js",
    "lint:syntax": "node scripts/syntax-check.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "express": "^4.18.2",
    "wrangler": "^4.99.0"
  }
}
